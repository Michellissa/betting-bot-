# === Database ===
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/betting_bot
DATABASE_SYNC_URL=postgresql+psycopg2://user:password@localhost:5432/betting_bot
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# === API Keys ===
# Football-Data.org (free tier: 10 requests/min, 12 leagues, no odds/xG)
FOOTBALL_DATA_API_KEY=your_api_key_here

# API-Football (rapidapi.com, free tier: 100 requests/day, broad coverage)
API_FOOTBALL_KEY=your_api_key_here
API_FOOTBALL_HOST=v3.football.api-sports.io

# The Odds API (the-odds-api.com, free tier: 500 requests/day)
ODDS_API_KEY=your_api_key_here

# TheStatsAPI (paid from $50/mo, 7-day trial, odds + xG + 10yr history)
THESTATSAPI_KEY=your_api_key_here

# Sportmonks (paid, modular add-on pricing, 2200+ leagues)
SPORTMONKS_KEY=your_api_key_here

# Sportradar (enterprise, requires sales contact)
SPORTRADAR_KEY=your_api_key_here

# Weather API (openweathermap.org)
WEATHER_API_KEY=your_api_key_here

# === Application ===
APP_NAME=BettingBot
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG
LOG_FORMAT=json
SECRET_KEY=change-me-to-a-random-secret

# === Model Training ===
TRAINING_FEATURE_VERSION=v1
MODEL_STORAGE_PATH=data/models
CACHE_ENABLED=true
CACHE_TTL=3600
REDIS_URL=redis://localhost:6379/0

# === Prediction ===
MIN_CONFIDENCE_THRESHOLD=0.50
MIN_EV_THRESHOLD=0.05
KELLY_FRACTION=0.25
DEFAULT_STAKE=100

# === CORS ===
CORS_ORIGINS=["http://localhost:8501","http://localhost:3000","http://localhost:8000"]
